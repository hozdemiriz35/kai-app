<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dr. Cos KAI — Kişisel Cilt Analizi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/style.css">
</head>
<body>



<!-- Arka plan -->
<div class="welcome-bg">
  <div class="bg-shape"></div>
  <div class="bg-shape"></div>
  <div class="bg-shape"></div>
</div>

<!-- Header -->
<div class="app-header">
  <h1>Dr. Cos KAI <span class="beta-badge" id="beta-badge">BETA</span></h1>
  <p>Yapay Zeka Destekli Cilt Analizi</p>
</div>

<!-- Progress -->
<div class="progress-wrap">
  <div class="progress-dots" id="progress-dots"></div>
  <div class="progress-bar-bg"><div class="progress-bar-fill" id="progress-bar-fill"></div></div>
  <div id="progress-label"></div>
</div>

<div class="app-wrap">

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 0 — KARŞILAMA                        -->
<!-- ══════════════════════════════════════════ -->
<div class="step active" id="step-0">
  <div style="text-align:center;padding:1rem 0 2rem">
    <div class="welcome-logo">🌿</div>
    <h1 class="welcome-title">Cildinizi Tanıyın</h1>
    <p class="welcome-sub">2 dakikada kişisel cilt analiziniz.<br>Bilimsel temelli, kişiselleştirilmiş bakım rehberi.</p>
    <div class="feature-badges">
      <span class="feature-badge">🔬 Bilimsel Analiz</span>
      <span class="feature-badge">🔒 Veri Güvende</span>
      <span class="feature-badge">📋 Kişisel Rapor</span>
    </div>
    <button class="btn-primary" style="max-width:320px;margin:0 auto;display:block"
      onclick="UI.showConsentModal()">Analize Başla →</button>
    <p style="margin-top:12px;font-size:12px;color:var(--muted)">Kayıt gerekmez • Ücretsiz • 2 dakika</p>
  </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 1 — KİŞİSEL BİLGİLER                -->
<!-- ══════════════════════════════════════════ -->
<div class="step" id="step-1">
  <div class="step-header">
    <h2>Sizi Tanıyalım</h2>
    <p>Analizimizi size özel yapalım</p>
  </div>

  <div class="section-label">Cinsiyet</div>
  <div class="grid3">
    <div class="card" data-group="gender" data-val="kadin" onclick="UI.selectCard(this,'gender')">
      <div class="card-icon">👩</div>
      <div class="card-title">Kadın</div>
    </div>
    <div class="card" data-group="gender" data-val="erkek" onclick="UI.selectCard(this,'gender')">
      <div class="card-icon">👨</div>
      <div class="card-title">Erkek</div>
    </div>
    <div class="card" data-group="gender" data-val="diger" onclick="UI.selectCard(this,'gender')">
      <div class="card-icon">✦</div>
      <div class="card-title">Belirtmek istemiyorum</div>
    </div>
  </div>

  <div class="section-label">Yaş</div>
  <div class="slider-wrap">
    <div class="slider-row">
      <span style="font-size:13px;color:var(--muted)">16</span>
      <input type="range" id="age" min="16" max="70" value="28" step="1"
        oninput="UI.updateSlider('age','age-display','')">
      <span style="font-size:13px;color:var(--muted)">70+</span>
    </div>
    <div style="text-align:center;margin-top:8px">
      <span class="slider-val" id="age-display">28</span>
      <span style="font-size:13px;color:var(--muted)"> yaş</span>
    </div>
    <div class="slider-labels"><span>Genç</span><span>Yetişkin</span><span>Olgun</span><span>Kıdemli</span></div>
  </div>

  <div class="section-label">Hamile veya emziriyor musunuz?</div>
  <div class="grid2">
    <div class="card" data-group="isPregnant" data-val="false" onclick="UI.selectCard(this,'isPregnant');AppState.userData.isPregnant=false">
      <div class="card-title">Hayır</div>
    </div>
    <div class="card" data-group="isPregnant" data-val="true" onclick="UI.selectCard(this,'isPregnant');AppState.userData.isPregnant=true">
      <div class="card-title">Evet</div>
      <div class="card-desc">Retinol gibi ürünler önerilmeyecek</div>
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-secondary" onclick="prevStep(1)">Geri</button>
    <button class="btn-primary" onclick="nextStep(1)">Devam →</button>
  </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 2 — CİLT TİPİ                        -->
<!-- ══════════════════════════════════════════ -->
<div class="step" id="step-2">
  <div class="step-header">
    <h2>Cilt Tipiniz</h2>
    <p>Size en uygun analiz için cilt tipinizi belirleyin</p>
  </div>

  <div class="card" data-group="skinType" data-val="normal" onclick="UI.selectCard(this,'skinType')">
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:28px">💧</span>
      <div><div class="card-title">Normal Cilt</div>
      <div class="card-desc">Dengeli, parlama yok, gerginlik yok. Şanslısınız!</div></div>
    </div>
  </div>
  <div class="card" data-group="skinType" data-val="yagli" onclick="UI.selectCard(this,'skinType')">
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:28px">✨</span>
      <div><div class="card-title">Yağlı Cilt</div>
      <div class="card-desc">Gün içinde yüz parlar, gözenekler belirgin, akne eğilimli</div></div>
    </div>
  </div>
  <div class="card" data-group="skinType" data-val="kuru" onclick="UI.selectCard(this,'skinType')">
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:28px">🌵</span>
      <div><div class="card-title">Kuru Cilt</div>
      <div class="card-desc">Gerginlik hissi, soyulma, mat ve donuk görünüm</div></div>
    </div>
  </div>
  <div class="card" data-group="skinType" data-val="karma" onclick="UI.selectCard(this,'skinType')">
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:28px">☯️</span>
      <div><div class="card-title">Karma Cilt</div>
      <div class="card-desc">Alın/burun yağlı (T-zone), yanaklar normal veya kuru</div></div>
    </div>
  </div>
  <div class="card" data-group="skinType" data-val="hassas" onclick="UI.selectCard(this,'skinType')">
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:28px">🌸</span>
      <div><div class="card-title">Hassas Cilt</div>
      <div class="card-desc">Kolayca kızarır, yanma / kaşıntı hissi, ürünlere reaksiyon verir</div></div>
    </div>
  </div>

  <p style="text-align:center;margin:.75rem 0">
    <a href="#" onclick="event.preventDefault();document.getElementById('skintype-helper-modal').classList.add('open');setTimeout(startHelperQuiz,50);" style="font-size:13px;color:var(--primary)">
      Emin değil misiniz? Yardımcı olalım →
    </a>
  </p>

  <div class="btn-row">
    <button class="btn-secondary" onclick="prevStep(2)">Geri</button>
    <button class="btn-primary" onclick="nextStep(2)">Devam →</button>
  </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 3 — PROBLEMLER                       -->
<!-- ══════════════════════════════════════════ -->
<div class="step" id="step-3">
  <div class="step-header">
    <h2>Cilt Problemleriniz</h2>
    <p>Şu an deneyimlediğiniz sorunları seçin. İstediğiniz kadar seçebilirsiniz.</p>
  </div>

  <div class="tags-wrap" id="problems-tags">
    <div class="tag" data-val="akne" onclick="UI.toggleTag(this,'problems-tags')">🔴 Akne & Sivilce</div>
    <div class="tag" data-val="kirisiklik" onclick="UI.toggleTag(this,'problems-tags')">〰️ Kırışıklık & İnce Çizgiler</div>
    <div class="tag" data-val="leke" onclick="UI.toggleTag(this,'problems-tags')">📍 Leke & Ton Eşitsizliği</div>
    <div class="tag" data-val="kuruluk" onclick="UI.toggleTag(this,'problems-tags')">💧 Kuruluk & Soyulma</div>
    <div class="tag" data-val="yaglillik" onclick="UI.toggleTag(this,'problems-tags')">✨ Aşırı Yağlanma</div>
    <div class="tag" data-val="hassasiyet" onclick="UI.toggleTag(this,'problems-tags')">🌸 Hassasiyet & Kızarıklık</div>
    <div class="tag" data-val="gozalti" onclick="UI.toggleTag(this,'problems-tags')">👁️ Göz Altı Morluğu</div>
    <div class="tag" data-val="sisme" onclick="UI.toggleTag(this,'problems-tags')">💫 Göz Altı Şişliği</div>
    <div class="tag" data-val="donukluk" onclick="UI.toggleTag(this,'problems-tags')">🌫️ Donuk & Cansız Görünüm</div>
    <div class="tag" data-val="genis_goz" onclick="UI.toggleTag(this,'problems-tags')">⭕ Büyük Gözenekler</div>
    <div class="tag" data-val="hicbiri" onclick="UI.toggleTag(this,'problems-tags')">✅ Hiçbiri</div>
  </div>

  <div class="section-label">Tanı konulmuş bir cilt hastalığınız var mı?</div>
  <div class="tags-wrap" id="diagnosis-tags">
    <div class="tag" data-val="rozase" onclick="UI.toggleTag(this,'diagnosis-tags')">🔴 Rozase</div>
    <div class="tag" data-val="egzama" onclick="UI.toggleTag(this,'diagnosis-tags')">🟠 Egzama</div>
    <div class="tag" data-val="psoriazis" onclick="UI.toggleTag(this,'diagnosis-tags')">🟡 Sedef (Psoriazis)</div>
    <div class="tag" data-val="alerjik" onclick="UI.toggleTag(this,'diagnosis-tags')">🟣 Alerjik Cilt</div>
    <div class="tag" data-val="hicbiri" onclick="UI.toggleTag(this,'diagnosis-tags')">✅ Hiçbiri</div>
  </div>

  <div class="btn-row">
    <button class="btn-secondary" onclick="prevStep(3)">Geri</button>
    <button class="btn-primary" onclick="nextStep(3)">Devam →</button>
  </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 4 — YAŞAM TARZI                      -->
<!-- ══════════════════════════════════════════ -->
<div class="step" id="step-4">
  <div class="step-header">
    <h2>Yaşam Tarzınız</h2>
    <p>Cilt sağlığının %40'ı yaşam tarzıyla ilgilidir</p>
  </div>

  <div class="section-label">💧 Günlük su tüketimi</div>
  <div class="water-select" id="water-select">
    <div class="water-btn" data-val="1" onclick="selectWater(this,'1')"><div class="water-icon">💧</div>1</div>
    <div class="water-btn" data-val="2" onclick="selectWater(this,'2')"><div class="water-icon">💧</div>2</div>
    <div class="water-btn" data-val="3" onclick="selectWater(this,'3')"><div class="water-icon">💧</div>3</div>
    <div class="water-btn" data-val="4" onclick="selectWater(this,'4')"><div class="water-icon">💧</div>4</div>
    <div class="water-btn" data-val="5" onclick="selectWater(this,'5')"><div class="water-icon">💧</div>5</div>
    <div class="water-btn" data-val="6" onclick="selectWater(this,'6')"><div class="water-icon">💧</div>6</div>
    <div class="water-btn" data-val="7" onclick="selectWater(this,'7')"><div class="water-icon">💧</div>7</div>
    <div class="water-btn" data-val="8+" onclick="selectWater(this,'8+')"><div class="water-icon">💧</div>8+</div>
  </div>
  <p id="water-label" style="font-size:13px;color:var(--primary);min-height:20px;margin-bottom:1rem"></p>

  <div class="section-label">🌙 Günlük uyku süresi</div>
  <div class="grid3">
    <div class="card" data-group="sleep" data-val="az" onclick="UI.selectCard(this,'sleep')">
      <div class="card-title">Az</div><div class="card-desc">5-6 saat</div>
    </div>
    <div class="card" data-group="sleep" data-val="normal" onclick="UI.selectCard(this,'sleep')">
      <div class="card-title">Normal</div><div class="card-desc">7-8 saat</div>
    </div>
    <div class="card" data-group="sleep" data-val="fazla" onclick="UI.selectCard(this,'sleep')">
      <div class="card-title">Yeterli</div><div class="card-desc">9+ saat</div>
    </div>
  </div>

  <div class="section-label">☀️ Güneş koruyucu kullanımı</div>
  <div class="grid3">
    <div class="card" data-group="spf" data-val="hic" onclick="UI.selectCard(this,'spf')">
      <div class="card-title">Kullanmıyorum</div>
    </div>
    <div class="card" data-group="spf" data-val="bazen" onclick="UI.selectCard(this,'spf')">
      <div class="card-title">Bazen</div>
    </div>
    <div class="card" data-group="spf" data-val="her" onclick="UI.selectCard(this,'spf')">
      <div class="card-title">Her gün</div>
    </div>
  </div>

  <div class="section-label">😰 Stres seviyeniz</div>
  <div class="stress-faces">
    <div style="text-align:center">
      <div class="stress-face" data-val="cok_dusuk" onclick="UI.selectStress(this)">😌</div>
      <div class="stress-label">Çok düşük</div>
    </div>
    <div style="text-align:center">
      <div class="stress-face" data-val="dusuk" onclick="UI.selectStress(this)">🙂</div>
      <div class="stress-label">Düşük</div>
    </div>
    <div style="text-align:center">
      <div class="stress-face" data-val="orta" onclick="UI.selectStress(this)">😐</div>
      <div class="stress-label">Orta</div>
    </div>
    <div style="text-align:center">
      <div class="stress-face" data-val="yuksek" onclick="UI.selectStress(this)">😟</div>
      <div class="stress-label">Yüksek</div>
    </div>
    <div style="text-align:center">
      <div class="stress-face" data-val="cok_yuksek" onclick="UI.selectStress(this)">😫</div>
      <div class="stress-label">Çok yüksek</div>
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-secondary" onclick="prevStep(4)">Geri</button>
    <button class="btn-primary" onclick="nextStep(4)">Analizi Başlat →</button>
  </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- ADIM 5 — FOTOĞRAF ANALİZİ (AKTİF)         -->
<!-- ══════════════════════════════════════════ -->
<div class="step" id="step-5">
  <div class="step-header">
    <h2>Fotoğraf Analizi</h2>
    <p>Fotoğrafınızdan yapay zeka ile cilt analizi yapılacak</p>
  </div>

  <!-- Yükleme / Çekim alanı -->
  <div id="photo-upload-area" style="background:var(--card);border:2px dashed var(--border);
    border-radius:var(--r);padding:2.5rem 1.5rem;text-align:center;margin-bottom:1rem;
    cursor:pointer;transition:border-color .2s"
    ondragover="event.preventDefault();this.style.borderColor='var(--primary)'"
    ondragleave="this.style.borderColor='var(--border)'"
    ondrop="handlePhotoDrop(event)">
    <div style="font-size:48px;margin-bottom:1rem">📸</div>
    <h3 style="margin-bottom:.5rem">Fotoğraf Yükle veya Çek</h3>
    <p style="font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:1.25rem">
      Sürükle bırak veya tıkla
    </p>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
      <button class="btn-outline" style="font-size:13px;padding:8px 18px"
        onclick="event.stopPropagation();document.getElementById('photo-file-input').click()">
        📁 Galeriden Seç
      </button>
      <button class="btn-outline" style="font-size:13px;padding:8px 18px"
        onclick="event.stopPropagation();startFourPhotoCapture()">
        📷 Kamera
      </button>
    </div>
    <input type="file" id="photo-file-input" accept="image/*" style="display:none"
      onchange="handleSinglePhotoSelect(this)">
  </div>

  <!-- İpucu -->
  <div style="background:#e8f5f1;border-radius:var(--r);padding:.75rem 1rem;
    font-size:12px;color:#0f6e56;margin-bottom:1rem;line-height:1.7">
    💡 <strong>İyi analiz için:</strong> Doğal ışıkta · Makyajsız · Düz bakarak · Net fotoğraf
  </div>

  <!-- 4 fotoğraf durumu (kamera ile çekilince görünür) -->
  <div id="photo-grid-area" style="display:none;margin-bottom:1rem">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:.5rem">
      <div id="slot-0" style="aspect-ratio:3/4;background:#f0ede8;border-radius:var(--r);
        overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center">
        <img id="grid-photo-0" style="display:none;width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        <div id="slot-placeholder-0" style="font-size:11px;color:var(--muted);text-align:center">
          <div style="font-size:24px;margin-bottom:4px">😐</div>Düz
        </div>
        <div id="slot-done-0" style="display:none;position:absolute;bottom:5px;right:5px;
          background:#2d9b7f;color:#fff;border-radius:50%;width:20px;height:20px;
          font-size:11px;display:none;align-items:center;justify-content:center">✓</div>
        <div style="position:absolute;top:5px;left:6px;font-size:9px;color:var(--muted);
          background:rgba(255,255,255,0.85);padding:1px 5px;border-radius:6px">1/4</div>
      </div>
      <div id="slot-1" style="aspect-ratio:3/4;background:#f0ede8;border-radius:var(--r);
        overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center">
        <img id="grid-photo-1" style="display:none;width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        <div id="slot-placeholder-1" style="font-size:11px;color:var(--muted);text-align:center">
          <div style="font-size:24px;margin-bottom:4px">👈</div>Sol
        </div>
        <div id="slot-done-1" style="display:none;position:absolute;bottom:5px;right:5px;
          background:#2d9b7f;color:#fff;border-radius:50%;width:20px;height:20px;
          font-size:11px;align-items:center;justify-content:center">✓</div>
        <div style="position:absolute;top:5px;left:6px;font-size:9px;color:var(--muted);
          background:rgba(255,255,255,0.85);padding:1px 5px;border-radius:6px">2/4</div>
      </div>
      <div id="slot-2" style="aspect-ratio:3/4;background:#f0ede8;border-radius:var(--r);
        overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center">
        <img id="grid-photo-2" style="display:none;width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        <div id="slot-placeholder-2" style="font-size:11px;color:var(--muted);text-align:center">
          <div style="font-size:24px;margin-bottom:4px">👉</div>Sağ
        </div>
        <div id="slot-done-2" style="display:none;position:absolute;bottom:5px;right:5px;
          background:#2d9b7f;color:#fff;border-radius:50%;width:20px;height:20px;
          font-size:11px;align-items:center;justify-content:center">✓</div>
        <div style="position:absolute;top:5px;left:6px;font-size:9px;color:var(--muted);
          background:rgba(255,255,255,0.85);padding:1px 5px;border-radius:6px">3/4</div>
      </div>
      <div id="slot-3" style="aspect-ratio:3/4;background:#f0ede8;border-radius:var(--r);
        overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center">
        <img id="grid-photo-3" style="display:none;width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
        <div id="slot-placeholder-3" style="font-size:11px;color:var(--muted);text-align:center">
          <div style="font-size:24px;margin-bottom:4px">☝️</div>Yukarı
        </div>
        <div id="slot-done-3" style="display:none;position:absolute;bottom:5px;right:5px;
          background:#2d9b7f;color:#fff;border-radius:50%;width:20px;height:20px;
          font-size:11px;align-items:center;justify-content:center">✓</div>
        <div style="position:absolute;top:5px;left:6px;font-size:9px;color:var(--muted);
          background:rgba(255,255,255,0.85);padding:1px 5px;border-radius:6px">4/4</div>
      </div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <span style="font-size:12px;color:var(--muted)">Fotoğraf durumu</span>
      <span id="photos-count-label" style="font-size:12px;font-weight:600;color:var(--primary)">0/4 tamamlandı</span>
    </div>
    <div style="background:var(--border);border-radius:4px;height:4px;margin-bottom:.75rem">
      <div id="photos-progress-bar" style="height:100%;width:0%;background:var(--primary);
        border-radius:4px;transition:width .3s"></div>
    </div>
    <button class="btn-secondary" style="width:100%;font-size:13px;padding:8px"
      onclick="resetPhotos()">🔄 Baştan Al</button>
  </div>

  <!-- Galeriden tek fotoğraf önizleme -->
  <div id="single-photo-preview" style="display:none;margin-bottom:1rem;text-align:center">
    <img id="single-photo-img" style="max-width:100%;max-height:260px;border-radius:var(--r);
      border:2px solid var(--primary)">
    <div style="margin-top:.75rem;display:flex;gap:10px;justify-content:center">
      <button class="btn-secondary" style="font-size:13px;padding:8px 16px"
        onclick="resetPhotos()">✕ Kaldır</button>
    </div>
  </div>

  <!-- KAI Analiz sonucu -->
  <div id="photo-result" style="display:none;margin-bottom:1rem">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:.75rem">
